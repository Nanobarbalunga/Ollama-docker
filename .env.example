# -----------------------------------------------------------------------------
# Common service names and policies
# -----------------------------------------------------------------------------
OLLAMA_CONTAINER_NAME=ollama
OPEN_WEBUI_CONTAINER_NAME=ollama-webui
OLLAMA_PULL_POLICY=always
OLLAMA_CPU_RESTART_POLICY=always
OLLAMA_GPU_RESTART_POLICY=unless-stopped
OPEN_WEBUI_RESTART_POLICY=unless-stopped

# -----------------------------------------------------------------------------
# Images
# -----------------------------------------------------------------------------
# CPU compose: docker-compose.yml
OLLAMA_IMAGE=ollama/ollama:latest
OPEN_WEBUI_CPU_IMAGE=ghcr.io/open-webui/open-webui:main

# NVIDIA compose: docker-compose-ollama-nvidia.yaml
OLLAMA_NVIDIA_IMAGE=ollama/ollama:latest

# AMD/ROCm compose: docker-compose-ollama-amd.yaml
OLLAMA_AMD_IMAGE=ollama/ollama:rocm

# Open WebUI GPU image. GPU compose files currently default to :latest.
OPEN_WEBUI_GPU_IMAGE=ghcr.io/open-webui/open-webui:latest

# -----------------------------------------------------------------------------
# Ports and bind paths
# -----------------------------------------------------------------------------
OLLAMA_PORT=7869
OPEN_WEBUI_PORT=8080
PROJECT_CODE_PATH=.
OLLAMA_DATA_PATH=./ollama/ollama
OPEN_WEBUI_DATA_PATH=./ollama/ollama-webui
OPEN_WEBUI_HOST_GATEWAY=host.docker.internal:host-gateway

# -----------------------------------------------------------------------------
# Ollama server configuration
# -----------------------------------------------------------------------------
OLLAMA_HOST=0.0.0.0
OLLAMA_KEEP_ALIVE=15m
OLLAMA_OPTS=--offload cpu

# Optional Ollama tuning. Uncomment in compose before using, or add directly there.
# OLLAMA_MODELS=/root/.ollama/models
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1
# OLLAMA_LOAD_TIMEOUT=5m
# OLLAMA_MAX_QUEUE=512
# OLLAMA_FLASH_ATTENTION=0
# OLLAMA_KV_CACHE_TYPE=f16

# -----------------------------------------------------------------------------
# Open WebUI configuration
# -----------------------------------------------------------------------------
# Multiple Ollama hosts are separated by semicolon.
OPEN_WEBUI_OLLAMA_BASE_URLS=http://ollama:11434
OPEN_WEBUI_ENV=dev
OPEN_WEBUI_AUTH=False
OPEN_WEBUI_NAME=OpenWebUi
OPEN_WEBUI_URL=http://localhost:8080
OPEN_WEBUI_SECRET_KEY=t0p-s3cr3t

# Optional Open WebUI integrations.
# OPEN_WEBUI_ENABLE_OLLAMA_API=True
# OPEN_WEBUI_OLLAMA_BASE_URL=http://ollama:11434
# OPEN_WEBUI_DEFAULT_MODELS=
# OPEN_WEBUI_ENABLE_OPENAI_API=True
# OPEN_WEBUI_OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPEN_WEBUI_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# SearXNG configuration
# -----------------------------------------------------------------------------
SEARXNG_CONTAINER_NAME=searxng
SEARXNG_IMAGE=searxng/searxng:latest
SEARXNG_PULL_POLICY=always
SEARXNG_RESTART_POLICY=unless-stopped
SEARXNG_PORT=8181
SEARXNG_CONFIG_PATH=./ollama/searxng
SEARXNG_CONFIG_MOUNT_OPTIONS=rw,Z
SEARXNG_BASE_URL=http://localhost:8181/
SEARXNG_SECRET_KEY=change-me-searxng-secret

# -----------------------------------------------------------------------------
# Open WebUI Web Search / SearXNG integration
# -----------------------------------------------------------------------------
OPEN_WEBUI_ENABLE_WEB_SEARCH=True
OPEN_WEBUI_WEB_SEARCH_ENGINE=searxng
OPEN_WEBUI_SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>&format=json
OPEN_WEBUI_SEARXNG_LANGUAGE=it
OPEN_WEBUI_WEB_SEARCH_RESULT_COUNT=3
OPEN_WEBUI_WEB_SEARCH_CONCURRENT_REQUESTS=1
OPEN_WEBUI_WEB_LOADER_CONCURRENT_REQUESTS=3
OPEN_WEBUI_WEB_SEARCH_TRUST_ENV=True
OPEN_WEBUI_BYPASS_WEB_SEARCH_WEB_LOADER=False
OPEN_WEBUI_BYPASS_WEB_SEARCH_EMBEDDING_AND_RETRIEVAL=False

# -----------------------------------------------------------------------------
# CPU profile
# -----------------------------------------------------------------------------
# No driver-specific variables are required for CPU-only usage.

# -----------------------------------------------------------------------------
# NVIDIA GPU profile
# -----------------------------------------------------------------------------
# Requires NVIDIA Container Toolkit configured on the Docker host.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
NVIDIA_GPU_COUNT=1
# NVIDIA_GPU_DEVICE_ID=0

# -----------------------------------------------------------------------------
# AMD GPU / ROCm profile
# -----------------------------------------------------------------------------
# Requires ROCm-compatible Linux devices exposed by the host.
AMD_KFD_DEVICE=/dev/kfd
AMD_DRI_DEVICE=/dev/dri
AMD_VIDEO_GROUP=video
AMD_RENDER_GROUP=render
AMD_HIP_VISIBLE_DEVICES=0
AMD_ROCR_VISIBLE_DEVICES=0
# Set only for GPUs that need an explicit ROCm architecture override.
# AMD_HSA_OVERRIDE_GFX_VERSION=10.3.0
